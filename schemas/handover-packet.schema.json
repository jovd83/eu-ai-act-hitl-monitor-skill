{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/handover-packet.schema.json",
  "x-version": "2.1.0",
  "title": "EU AI Act HITL Handover Packet",
  "description": "Structured human-review packet for high-risk or sensitive agent actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handover_id",
    "created_at",
    "trace_id",
    "run_id",
    "agent",
    "policy",
    "trigger",
    "pending_action",
    "explanation",
    "review_guidance",
    "review_requirements",
    "human_options",
    "audit",
    "review"
  ],
  "properties": {
    "example_version": {
      "type": "string",
      "minLength": 1
    },
    "handover_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "policy_version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "policy_version",
        "policy_reference",
        "review_required"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "policy_reference": {
          "type": "string",
          "minLength": 1
        },
        "review_required": {
          "type": "boolean"
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "matched_rules",
        "risk_level"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "low_confidence",
            "sensitive_action",
            "anomaly",
            "loop",
            "policy_violation"
          ]
        },
        "matched_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      }
    },
    "pending_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "tool_name",
        "tool_args_redacted",
        "side_effects",
        "affected_resources"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "tool_args_redacted": {
          "type": "object"
        },
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "affected_resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "why_now",
        "evidence_summary",
        "reasoning_summary",
        "uncertainty_summary",
        "known_risks"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "why_now": {
          "type": "string",
          "minLength": 1
        },
        "evidence_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reasoning_summary": {
          "type": "string",
          "minLength": 1
        },
        "uncertainty_summary": {
          "type": "string",
          "minLength": 1
        },
        "known_risks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questions",
        "recommended_actions"
      ],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_actions": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_reviewer_role",
        "decision_deadline_at",
        "fallback_on_timeout",
        "allow_reassignment"
      ],
      "properties": {
        "required_reviewer_role": {
          "type": "string",
          "minLength": 1
        },
        "decision_deadline_at": {
          "type": "string",
          "format": "date-time"
        },
        "fallback_on_timeout": {
          "type": "string",
          "enum": [
            "keep_paused",
            "reject",
            "kill",
            "escalate"
          ]
        },
        "escalation_contact": {
          "type": "string",
          "minLength": 1
        },
        "allow_reassignment": {
          "type": "boolean"
        }
      }
    },
    "human_options": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "approve",
          "modify",
          "reject",
          "kill",
          "request_more_context"
        ]
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_payload_version",
        "redaction_notes",
        "evidence_refs"
      ],
      "properties": {
        "review_payload_version": {
          "type": "string",
          "minLength": 1
        },
        "redaction_notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer_id",
        "review_started_at",
        "review_submitted_at",
        "review_duration_ms",
        "decision_reason",
        "modifications"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approve",
            "modify",
            "reject",
            "kill",
            "request_more_context",
            "timeout"
          ]
        },
        "reviewer_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_submitted_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "decision_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "modifications": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "human_options": {
          "contains": {
            "const": "approve"
          }
        }
      }
    },
    {
      "properties": {
        "human_options": {
          "contains": {
            "const": "modify"
          }
        }
      }
    },
    {
      "properties": {
        "human_options": {
          "contains": {
            "const": "reject"
          }
        }
      }
    },
    {
      "properties": {
        "human_options": {
          "contains": {
            "const": "kill"
          }
        }
      }
    },
    {
      "properties": {
        "human_options": {
          "contains": {
            "const": "request_more_context"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review": {
            "properties": {
              "status": {
                "const": "pending"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "reviewer_id": {
                "type": "null"
              },
              "review_started_at": {
                "type": "null"
              },
              "review_submitted_at": {
                "type": "null"
              },
              "review_duration_ms": {
                "type": "null"
              },
              "decision_reason": {
                "type": "null"
              },
              "modifications": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review": {
            "properties": {
              "status": {
                "const": "modify"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "reviewer_id": {
                "type": "string",
                "minLength": 1
              },
              "review_started_at": {
                "type": "string",
                "format": "date-time"
              },
              "review_submitted_at": {
                "type": "string",
                "format": "date-time"
              },
              "review_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "decision_reason": {
                "type": "string",
                "minLength": 1
              },
              "modifications": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review": {
            "properties": {
              "status": {
                "enum": [
                  "approve",
                  "reject",
                  "kill",
                  "request_more_context"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "reviewer_id": {
                "type": "string",
                "minLength": 1
              },
              "review_started_at": {
                "type": "string",
                "format": "date-time"
              },
              "review_submitted_at": {
                "type": "string",
                "format": "date-time"
              },
              "review_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "decision_reason": {
                "type": "string",
                "minLength": 1
              },
              "modifications": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review": {
            "properties": {
              "status": {
                "const": "timeout"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "review_submitted_at": {
                "type": "string",
                "format": "date-time"
              },
              "review_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "decision_reason": {
                "type": "string",
                "minLength": 1
              },
              "modifications": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ]
}
