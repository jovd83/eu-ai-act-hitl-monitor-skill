{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/review-decision.schema.json",
  "x-version": "2.1.0",
  "title": "EU AI Act HITL Review Decision",
  "description": "Structured human decision contract for resuming, modifying, rejecting, or halting a paused agent action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "handover_id",
    "reviewed_handover_version",
    "decision",
    "reviewer_id",
    "reviewer_role",
    "decision_source",
    "review_started_at",
    "review_submitted_at",
    "review_duration_ms",
    "decision_reason"
  ],
  "properties": {
    "example_version": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "handover_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_handover_version": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "modify",
        "reject",
        "kill",
        "request_more_context"
      ]
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_role": {
      "type": "string",
      "minLength": 1
    },
    "decision_source": {
      "type": "string",
      "enum": [
        "ui",
        "api",
        "webhook",
        "batch"
      ]
    },
    "review_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "decision_reason": {
      "type": "string",
      "minLength": 1
    },
    "modifications": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "updated_action",
        "changed_fields",
        "replacement_args",
        "original_action_blocked"
      ],
      "properties": {
        "updated_action": {
          "type": "string",
          "minLength": 1
        },
        "changed_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "replacement_args": {
          "type": "object"
        },
        "original_action_blocked": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "modify"
          }
        }
      },
      "then": {
        "required": [
          "modifications"
        ],
        "properties": {
          "modifications": {
            "type": "object"
          }
        }
      },
      "else": {
        "properties": {
          "modifications": {
            "type": "null"
          }
        }
      }
    }
  ]
}
